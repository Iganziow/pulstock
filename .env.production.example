# ══════════════════════════════════════════════════════════════════════════════
# .env.production — Backend en Hetzner
# Frontend en Vercel (ver sección de Vercel más abajo)
# Copiar este archivo como .env.production y completar los valores
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=pulstock
POSTGRES_USER=pulstock
POSTGRES_PASSWORD=CAMBIA_ESTO

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=GENERA_CON__python_-c_"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.pulstock.cl
DJANGO_ADMIN_URL=gestion-CAMBIA_ESTO/

DATABASE_URL=postgres://pulstock:CAMBIA_ESTO@db:5432/pulstock
CELERY_BROKER_URL=redis://redis:6379/0

# Frontend Vercel + preview URLs (separadas por coma)
WEB_ORIGIN=https://pulstock.cl,https://www.pulstock.cl

# URLs públicas
API_BASE_URL=https://api.pulstock.cl
APP_BASE_URL=https://pulstock.cl

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=Pulstock <noreply@pulstock.cl>

# ── Flow.cl ───────────────────────────────────────────────────────────────────
PAYMENT_GATEWAY=flow
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://www.flow.cl/api

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Activar solo después de registrar en https://hstspreload.org
DJANGO_HSTS_PRELOAD=0

# ── Logging (opcional) ────────────────────────────────────────────────────────
# DJANGO_LOG_FILE=/var/log/pulstock/api.log
# DB_CONN_MAX_AGE=60

# ══════════════════════════════════════════════════════════════════════════════
# VERCEL — Variables a configurar en el dashboard de Vercel
# Project Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# NEXT_PUBLIC_API_URL=https://api.pulstock.cl/api
#
