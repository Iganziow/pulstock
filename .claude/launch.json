{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (Django)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["manage.py", "runserver", "0.0.0.0:8000"],
      "port": 8000,
      "autoPort": false,
      "cwd": "apps/api"
    },
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/next/dist/bin/next", "dev", "-p", "3000"],
      "port": 3000,
      "autoPort": false,
      "cwd": "apps/web"
    }
  ]
}
