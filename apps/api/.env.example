# ============================================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env
# ============================================================

# ------ Django core ------
# Genera con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-segura

# 1 = desarrollo, 0 = producción
DJANGO_DEBUG=1

# En producción: DJANGO_ALLOWED_HOSTS=midominio.com,www.midominio.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ------ Base de datos ------
# Desarrollo: dejar vacío para usar SQLite
# Producción: DATABASE_URL=postgres://usuario:contraseña@host:5432/nombre_db
DATABASE_URL=

# ------ CORS ------
WEB_ORIGIN=http://localhost:3000

# ------ Pagos Flow.cl ------
# Gateway: "mock" (dev sin credenciales) o "flow" (sandbox/producción)
PAYMENT_GATEWAY=mock

# Obtener desde https://sandbox.flow.cl/app/web/misDatos.php (sandbox)
# o https://www.flow.cl/app/web/misDatos.php (producción)
FLOW_API_KEY=
FLOW_SECRET_KEY=

# Sandbox: https://sandbox.flow.cl/api
# Producción: https://www.flow.cl/api
FLOW_BASE_URL=https://sandbox.flow.cl/api

# ------ URLs de la app ------
# URL pública del backend Django (para webhooks de Flow)
# En desarrollo local: usar ngrok → API_BASE_URL=https://xxxx.ngrok.io
API_BASE_URL=http://localhost:8000

# URL del frontend Next.js (para redirigir al usuario tras pagar)
APP_BASE_URL=http://localhost:3000
